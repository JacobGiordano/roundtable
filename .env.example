# Roundtable — build-time environment variables
# Copy to .env.local for local overrides. Never commit .env.local.

# GitHub Pages deployment — sets Vite's base path.
# Set to /roundtable/ when building for GitHub Pages (done automatically by
# the deploy-pages workflow). Leave unset for local dev and self-hosted builds.
VITE_BASE=

# Pricing table URL — overrides the canonical GitHub raw URL for local dev or
# self-hosted builds that serve their own pricing.json. Leave unset in production
# (the app falls back to the canonical URL). In local dev, set to /pricing.json
# so Vite's dev server serves it directly without hitting GitHub raw.
VITE_PRICING_URL=

# Legacy proxy overrides — build-time alternatives to the runtime proxy URL
# configured in Settings → Connection Proxy. These are kept for backward
# compatibility with existing self-hosted deployments. New deployments should
# use the runtime proxy URL instead.
VITE_ANTHROPIC_PROXY_URL=
VITE_OPENAI_PROXY_URL=
