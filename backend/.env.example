# Roundtable Backend — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Port the server listens on
PORT=3001

# Secret used to sign JWTs. Change this to a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# Path to the SQLite database file.
# When running with Docker Compose this should be inside the /app/data mount.
DATABASE_PATH=./roundtable.db

# Admin user created on first startup (when the users table is empty).
# Change these before deploying. After the first startup these have no effect —
# use the API to manage users if you need to add more in the future.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
